@import './base.wxss';

.cellTitle {
  font-size: 16px;
  font-weight: 500;
  line-height: 28px;
}

.cellVal {
  color: #999999;
}

.add {
  font-size: 15px !important;
}

.add text {
  font-weight: bold;
}

.orgBtn {
  font-size: 16px !important;
}

.cellCls {
  padding: 16px !important;
}

/**
* 操作
*/
.bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  backdrop-filter: blur(5px);
  z-index: 99999;
}

.bar-item {
  flex: 2;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  margin: 0 2%;
  color: #333333;
  font-size: 14px;
}

.bar-item .txt {
  padding-top: 10rpx;
  color: #333333;
  font-size: 11px;
}