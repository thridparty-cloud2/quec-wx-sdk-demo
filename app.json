{
  "pages": [
    "pages/home/home",
    "pages/home/sub/non/search/index",
    "pages/mine/mine"
  ],
  "subpackages": [
    {
      "root": "ble",
      "name": "ble",
      "pages": [
        "device_add/index"
      ]
    },
    {
      "root": "user",
      "name": "user",
      "pages": [
        "index/index",
        "info/index",
        "about/v1/home/index",
        "about/v1/video/index",
        "about/v2/home/index",
        "setting/index",
        "login/index",
        "valid_code/index",
        "forget/index",
        "register/index",
        "msg/index"
      ]
    },
    {
      "root": "panel",
      "name": "panel",
      "pages": [
        "no_data/index",
        "general/index/index",
        "general/arr/index",
        "general/txt/index",
        "general/struct/index",
        "general/struct_txt/index",
        "general/rename/index",
        "general/alarm/index"
      ]
    }
  ],
  "window": {
    "backgroundTextStyle": "dark",
    "navigationBarBackgroundColor": "#fff",
    "navigationBarTitleText": "",
    "navigationBarTextStyle": "black",
    "navigationStyle": "custom",
    "backgroundColor": "#F7F8FC",
    "handleWebviewPreload": "auto"
  },
  "networkTimeout": {
    "request": 180000,
    "connectSocket": 180000
  },
  "plugins": {
    "quecPlugin": {
      "version": "3.0.0",
      "provider": "wx8b0625890b89be58"
    }
  },
  "resolveAlias": {
    "~/*": "/*"
  },
  "usingComponents": {
    "nav_bar": "/comps/nav_bar/nav_bar"
  },
  "tabBar": {
    "custom": true,
    "color": "#646464",
    "selectedColor": "#3C3C3C",
    "borderStyle": "white",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的"
      }
    ]
  },
  "preloadRule": {
    "pages/home/home": {
      "network": "wifi",
      "packages": [
        "panel"
      ]
    }
  },
  "requiredPrivateInfos": [
    "getLocation",
    "chooseLocation"
  ],
  "permission": {
    "scope.userLocation": {
      "desc": "您的位置信息将用于添加地址"
    },
    "scope.record": {
      "desc": "需要获取您的录音权限"
    }
  },
  "lazyCodeLoading": "requiredComponents",
  "sitemapLocation": "sitemap.json"
}