@import '/asset/icon.wxss';

page,
.cancel {
  height: 100%;
  overflow: hidden;
  position: relative;
}

.cancel {
  padding: 40rpx;
}

.img {
  padding: 20rpx 0 30rpx;
}

.icon {
  text-align: center;
}

.cimg {
  width: 72px;
  height: 72px;
}

.note {
  font-size: 20px;
  color: #333333;
  padding: 10rpx 0 20rpx;
  text-align: center;
  font-weight: 500;
}

.ntip {
  margin-top: 30rpx;
}

.ntip .tit {
  font-size: 14px;
  font-weight: 500;
  color: #333333;
  padding: 30rpx 0;
  border-bottom: 1px solid #F3F3F4;
}

.per {
  font-size: 14px;
  color: #666666;
  line-height: 48rpx;
  margin-top: 30rpx;
}

.btns {
  margin-top: 40rpx;
  position: absolute;
  width: 100%;
  left: 0;
  bottom: 140px;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.cancelBtn {
  font-size: 16px;
}

.cancel_now {
  text-align: center;
  font-size: 14px;
  color: #999999;
  padding: 40rpx 0;
  height: 40rpx;
  line-height: 40rpx;
}