@import '/asset/nav.wxss';

.head {
  display: flex;
  min-height: 560rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.contact {
  text-align: center;
  position: fixed;
  bottom: 30px;
  width: 100%;
  left: 0;
}

.contact text {
  height: 80rpx;
  line-height: 80rpx;
  font-size: 12px;
  color: #9C9FA3;
  display: inline-block;
}

.contact .tel {
  padding: 0 20rpx 0 10rpx;
}

.head .txt {
  font-size: 14px;
  color: #9C9FA3;
  padding-top: 30rpx;
  font-weight: 500;
}

.cellTitle {
  font-size: 16px;
  color: #080F19;
  font-weight: bold;
}

.van-cell {
  background-color: transparent !important;
  padding: 18px 20px !important;
}

.con .van-icon,
.con .van-icon:before {
  color: #CECFD1;
  font-size: 14px;
}