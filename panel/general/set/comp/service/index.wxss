.size24 {
  width: 24px;
  height: 24px;
}

.tit {
  font-size: 12px;
  font-weight: 500;
  color: #6B6F75;
  padding: 40rpx 40rpx 10rpx 30rpx;
}

.service .item .txt {
  color: #080F19;
  font-size: 14px;
  font-weight: 500;
  line-height: 22px;
  padding-top: 10rpx;
}

.service {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 20px;
  margin: 40rpx;
}

.service .item {
  text-align: center;
}

.line {
  width: 94%;
  height: 1px;
  margin: 0 auto;
  background: #efefef;
}