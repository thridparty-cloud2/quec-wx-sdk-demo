.fun {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin: 40rpx;
}

.fun .item {
  border-radius: 12px;
  background: #F7F8FC;
  padding: 30rpx 40rpx;
}

.fun .item .txt,
.service .item .txt {
  color: #080F19;
  font-size: 14px;
  font-weight: 500;
  line-height: 22px;
  padding-top: 10rpx;
}

.size24 {
  width: 24px;
  height: 24px;
}

.new {
  background: #FF4219;
  padding: 2px 5px;
  color: #ffffff;
  border-radius: 22px;
  text-transform: uppercase;
  font-size: 10px;
}