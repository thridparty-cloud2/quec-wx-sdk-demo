<view class="p_main">
  <form bindsubmit="formSubmit">
    <van-field model:value="{{ tslVal }}" size="large" type="textarea" placeholder="{{i18n['attrHolder']}}" bind:change="changeCon" autosize border="{{ false }}" maxlength="{{maxlength}}" adjust-position="false" />
    <view class="btns">
      <view class="btnItem">
        <van-button custom-class="tslBtn" custom-style="{{'border-radius:'+skin['radius']}}" disabled="{{ tslVal.length > 0 ? false : true }}" block form-type="submit" color="{{ skin['primary'] }}">{{i18n['confirmBtn']}}</van-button>
      </view>
    </view>
  </form>
</view>
