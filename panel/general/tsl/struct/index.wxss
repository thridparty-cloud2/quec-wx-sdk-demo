@import '/asset/base.wxss';

.p_main {
  padding: 20rpx;
}

.btns {
  position: fixed;
  left: 0;
  bottom: 0;
  right: 0;
  height: 120rpx;
  background: #F7F8FC;
  padding: 20rpx 40rpx 40rpx;
  margin: 0;
  z-index: 999;
}

.con {
  padding-bottom: 150rpx;
}

.all {
  font-size: 12px;
  padding: 0 30rpx 30rpx;
}

.all text {
  background: #efefef;
  padding: 10rpx 30rpx;
  border-radius: 10rpx;
}

.box {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
}

.item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 40rpx 20rpx;
  background: #ffffff;
  border-bottom: 1px solid #efefef;
}

.left,
.right {
  display: flex;
  flex-direction: row;
  overflow: hidden;
}

.left {
  flex: auto;
  justify-content: flex-start;
}

.right {
  justify-content: flex-end;
}

.right .val {
  font-size: 14px;
  color: #666666;
  width: 140px;
  text-align: right;
}

.cellTitle {
  padding-left: 16rpx;
}

.tslBtn {
  font-size: 16px;
  border-radius: 10px;
}

.action {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 30rpx 40rpx 30rpx 35rpx;
}

.action .txt {
  font-size: 12px;
  color: #999999;
}

.argInput {
  margin: 40rpx 30rpx;
}