@import '/asset/icon.wxss';

.sendDynamic {
  height: 58px;
  width: 58px;
  bottom: 200rpx;
  right: 50rpx;
  position: fixed;
}

.mask-con {
  transition: 0.5s;
  position: fixed;
  height: 58px;
  width: 58px;
  bottom: -100rpx;
  right: 40rpx;
  opacity: 0;
  box-shadow: 0 4px 12px rgba(0, 145, 255, .1);
  border-radius: 100%;
  text-align: center;
  line-height: 58px;
  background: #0091FF;
  z-index: 100;
}

.mask-con-show {
  bottom: 50rpx;
  opacity: 1;
}

.shadow {
  position: fixed;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, .4);
}

.gateway-box {
  bottom: 480rpx;
  right: 20rpx;
  position: fixed;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.device-box {
  bottom: 340rpx;
  right: 20rpx;
  position: fixed;
  display: flex;
  align-items: center;
}

.saoma-box {
  bottom: 540rpx;
  right: 20rpx;
  position: fixed;
  display: flex;
  align-items: center;
}

.icon {
  height: 50px;
  width: 50px;
}

.tips {
  width: 85px;
  height: 34px;
}

.settings {
  font-size: 34px;
  color: #ffffff;
}