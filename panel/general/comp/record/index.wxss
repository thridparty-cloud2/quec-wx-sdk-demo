@import '../../../../asset/base.wxss';

.step {
  padding: 30rpx 30rpx 30rpx 50rpx;
  background: #ffffff;
}

.line {
  margin: 12% auto;
  width: 4rpx;
  height: 87%;
}

.left {
  position: relative;
  top: 10rpx;
}

.icon {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.right {
  margin-left: 30rpx;
  padding-bottom: 20rpx;
}

.title {
  color: #080F19;
  font-size: 16px;
  font-weight: 500;
}

.content {
  font-size: 13px;
  color: #999999;
  padding-top: 8rpx;
}

.time {
  font-size: 12px;
  color: #999999;
  padding-top: 16rpx;
}

.bg_E6E7E8 {
  background: #E6E7E8;
}