@import "/asset/base.wxss";

page,
.bgCls {
  overflow: hidden;
  background: #fff;
}

.info {
  margin: 50rpx 40rpx 0;
  height: 50px;
  position: relative;
}

.basic {
  width: 130px;
  position: relative;
  left: 0;
  top: -10%;
  z-index: 10;
}

.info .sound {
  position: absolute;
  z-index: 20;
  right: 0;
  top: 65%;
}

.info .icon {
  display: block;
  margin: 0 auto;
}

.info .sound .txt {
  padding: 2px 6px;
  gap: 4px;
  border-radius: 10px;
  background: #ffffff;
  margin-top: -6px;
  font-size: 12px;
  color: #000;
}

.bg {
  width: 100%;
  height: 310px;
  margin: 0 auto;
  display: block;
  position: relative;
}

.size60 {
  width: 60px;
  height: 48px;
}

.rightIcon {
  padding-right: 198rpx !important;
}

.sim-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  z-index: 888;
}
