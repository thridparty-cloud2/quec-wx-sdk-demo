@import "/asset/icon.wxss";

.del-histroy-container {
  height: 52px;
  width: 60px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 16px;
}

.delete {
  font-size: 17px;
  color: #080f19;
}

.dialog-content {
  padding: 20px 24px 28px;
}

.dialog-title {
  font-size: 16px;
  font-weight: 600;
  color: #080f19;
  text-align: center;
  margin-bottom: 20px;
}

.option-item {
  position: relative;
  padding: 12px 10px;
  margin-bottom: 12px;
  border-radius: 8px;
  border: 1px solid #f7f8fc;
  background-color: #f7f8fc;
}

.option-item:last-child {
  margin-bottom: 0;
}

.option-item.beselected {
  border: 1px solid #0091ff;
}

.option-text {
  font-size: 14px;
  font-weight: 500;
  color: #6b6f75;
}

.option-item.beselected .option-text {
  color: #0091ff;
}

.marker-icon {
  position: absolute;
  top: -1px;
  right: -1px;
  width: 20px;
  height: 16px;
}

.confirm-btn {
  font-size: 16px !important;
  font-weight: 600 !important;
  color: #080f19 !important;
}

.cancel-btn {
  font-size: 16px !important;
  font-weight: 600 !important;
  color: #080f19 !important;
}
