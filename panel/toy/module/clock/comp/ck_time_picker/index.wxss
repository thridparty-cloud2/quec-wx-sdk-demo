.time-picker {
  height: 200px;
  overflow: hidden;
  margin-bottom: 12px;
}

.picker-view {
  width: 100%;
  height: 100%;
}

.picker-item {
  text-align: center;
  font-size: 16px;
  font-weight: 400;
  color: #00000099;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-item.selected-item {
  color: #000000e5 !important;
  font-weight: 600 !important;
  font-size: 16px !important;
}

.selected-column::after {
  border: none;
}

.selected-column::before {
  border: none;
}

.selected-column {
  height: 40px;
}

.item .selected-column {
  z-index: -1;
}

.item1 .selected-column {
  border-radius: 6px 0 0 6px;
  background-color: #ffffff;
}

.item2 .selected-column {
  border-radius: 0 6px 6px 0;
  background-color: #ffffff;
}
