@import "../../../../../asset/nav.wxss";
@import "../../../../../asset/base.wxss";
@import "../../../../../asset/icon.wxss";

page,
.roleMain {
  overflow: hidden;
  padding: 0;
}

.van-nav-bar {
  background-color: #f7f8fc !important;
}

.main {
  flex: 1;
  width: 94%;
  padding-left: 3%;
  padding-right: 3%;
}

.role-add-img-view {
  height: 180px !important;
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: center;
  margin: 8px 0;
}

.role-add-img-view .role-add-img-select {
  height: 180px;
  width: 180px;
  background-color: #fff;
  border-radius: 12px;
  position: relative;
}

.role-add-img-select-text {
  color: #9c9fa3;
  font-size: 16px;
  font-weight: 400;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  white-space: nowrap;
}

.role-pic {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.role-pic-reload {
  position: absolute;
  top: 149px;
  right: -31px;
}

.role-scroll {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  height: 100vh;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  position: relative;
  padding-bottom: 180px;
}

.role-edit-cell {
  border-radius: 12px;
  margin-top: 20px;
}

.role-edit-cell-input-row {
  display: flex;
  flex-direction: column;
}

.role-name-input-container {
  margin-top: 8px;
  padding: 16px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 400;
  background-color: #fff;
}

.role-edit-cell-input .role-edit-input-col {
  min-height: 90px;
  width: 100%;
  box-sizing: border-box;
  font-size: 14px;
  line-height: 22px;
  padding-bottom: 10px;
  height: 100%;
}

.role-item-right-radio {
  margin-left: 12px;
}

.voice-cell-title-text-voice {
  margin-left: 6px;
}

.voice-cell-title-text {
  display: flex;
  align-items: center;
  font-weight: 600;
  font-size: 14px !important;
  color: #080f19;
}

.voice-cell-title-text-prompt {
  justify-content: space-between;
}

.role-scroll .role-item-right-radio .van-radio__label {
  width: 0 !important;
  padding: 0 !important;
}

.role-add-page .confirm-edit-role-button .van-button__text {
  font-weight: 600;
  font-size: 16px;
}

.role-add-page .confirm-edit-role-button {
  width: 100%;
}

.confirm-button-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #ffffff;
  padding: 10px 20px 36px;
  box-sizing: border-box;
  z-index: 100;
}

.role-add-page .confirm-edit-role-button.van-button--disabled {
  border-color: transparent !important;
  border-width: 0 !important;
}

.van-button--disabled {
  background: #0091ff73 !important;
}

.role-add-popup-nav-bar {
  padding-top: 0px !important;
  background-color: #f7f8fc !important;
}

.grid {
  padding: 12px 12px 40px 12px;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
  margin-top: 40rpx 0;
}

.grid .avatar-shell {
  /* width: 100px;
  height: 100px; */
  border-radius: 8px;
  background-color: #fff;
  /* padding: 5px; */
  display: flex;
  justify-content: center;
  align-items: center;
  border: 1px solid transparent;
}

.grid .avatar-shell .avatar {
  width: 90px;
  height: 90px;
  box-sizing: border-box;
}

.grid .selected-img {
  border-color: #007aff;
}

/* 必填标识样式 */
.required-mark {
  color: #ff4444;
  font-size: 16px;
  margin-right: 2px;
}

/* 角色编辑单元格头部样式 */
.role-edit-cell-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

/* 字符计数样式 */
.char-count {
  color: #9c9fa3;
  font-size: 14px;
  font-weight: 400;
}

/* textarea容器样式 */
.textarea-container {
  /* overflow: hidden; */
  background-color: #fff;
  border-radius: 12px;
  padding: 16px;
  position: relative;
  margin-top: 8px;
  height: 134px;
}

.textarea-prompt {
  min-height: 400px !important;
}

/* 字符计数覆盖层样式 */
.char-count-overlay {
  position: absolute;
  bottom: 14px;
  right: 12px;
  font-size: 12px;
  font-weight: 400;
  color: #9c9fa3;
  pointer-events: none;
  z-index: 1;
  height: fit-content;
}

.voice-cell {
  padding: 12px !important;
  display: flex;
  justify-content: center;
  align-items: center;
}

.title {
  display: flex;
  align-items: center;
}

.polish {
  display: flex;
  align-items: center;
}

.polish-disabled {
  opacity: 0.5;
}

.polish-text,
.polishing-text {
  font-size: 14px;
  font-weight: 500;
  margin-left: 2px;
}

.polish-text {
  background: linear-gradient(254.84deg, #22e5ff -11.55%, #663efc 73.18%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.polishing-text {
  color: #9c9fa3;
}

.prompt-template-list {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin: 8px 0 8px 0;
}

.prompt-template-item {
  width: 88px;
  height: 18px;
  margin-right: 4px;
  padding: 4px 8px;
  border-radius: 4px;
  background-color: #fff;
  border: 1px solid #e7e7e7;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b6f75;
  font-size: 12px;
  font-weight: 400;
}

.delete-role {
  width: 32px;
  height: 32px;
  right: 0;
  position: absolute;
  border: 1px solid #97979733;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shanchu1 {
  font-size: 24px;
}

/* 删除图标禁用态样式 */
.icon-disabled {
  color: #c7c7c7 !important;
}

.van-dialog__header {
  font-size: 16px !important;
  font-weight: 600 !important;
}

.del-role-dialog .van-button {
  font-size: 16px !important;
  font-weight: 600 !important;
}

.van-nav-bar__title {
  font-size: 16px !important;
  font-weight: 600 !important;
}