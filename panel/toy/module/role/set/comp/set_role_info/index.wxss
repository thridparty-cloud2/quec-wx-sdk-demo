@import "/asset/icon.wxss";

.role-info {
  border-radius: 24px;
  padding: 0 24px 0 24px;
  margin-top: 120px;
  background-color: #ffffff;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.role-pic {
  width: 190px;
  height: 180px;
  position: absolute;
  top: -100px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.role-name {
  font-size: 20px;
  font-weight: 600;
  color: #080f19;
  margin: 95px 0 25px 0;
}

.role-des {
  width: 286px;
  max-height: 98px;
  font-size: 14px;
  font-weight: 400;
  margin-bottom: 12px;
  letter-spacing: 0%;
  color: #6b6f75;
  word-break: break-all;
  word-wrap: break-word;
  overflow-wrap: break-word;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  line-clamp: 5;
  box-orient: vertical;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
}

.role-prompt-container {
  width: 286px;
  max-height: 40px;
  margin: 0 0 12px 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.role-prompt {
  max-height: 98px;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 14px;
  font-weight: 400;
  color: #6b6f75;
  word-break: break-all;
  word-wrap: break-word;
  overflow-wrap: break-word;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  line-clamp: 2;
  box-orient: vertical;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.role-prompt-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: row;
  gap: 8px;
}

.loading-text {
  font-size: 12px;
  color: #999;
  font-weight: 400;
}

.edit-btn {
  width: 76px;
  height: 32px;
  padding: 4px 12px;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f7f8fc;
  border: none;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 400;
  color: #6b6f75;
}

.edit-text {
  margin-left: 4px;
}

.sdk-icon.writing {
  font-size: 24px;
}

.driver {
  height: 1px;
  width: 286px;
  margin-bottom: 12px;
  background-color: #f7f8fc;
}
