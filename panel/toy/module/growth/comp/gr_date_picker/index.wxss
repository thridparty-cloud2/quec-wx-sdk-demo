.date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 0 16px;
  overflow: hidden;
}

.picker-view {
  width: 100%;
  height: 90%;
}

.selected-item {
  font-weight: 600;
}

.picker-item {
  text-align: center;
  font-size: 16px;
  font-weight: 400;
  color: #00000099;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-item.selected-item {
  color: #000000e5 !important;
  font-weight: 600 !important;
  font-size: 16px !important;
}

.selected-column {
  height: 40px;
}

.selected-column::after {
  border: none;
}

.selected-column::before {
  border: none;
}

.item .selected-column {
  z-index: -1;
}

.item1 .selected-column {
  border-radius: 6px 0 0 6px;
  background-color: #f3f3f3;
}

.item2 .selected-column {
  background-color: #f3f3f3;
}

.item3 .selected-column {
  border-radius: 0 6px 6px 0;
  background-color: #f3f3f3;
}

.popup {
  border-radius: 20px 20px 0 0 !important;
}

.popup-content {
  background: #fff;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.popup-header {
  height: 58px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.popup-header .title {
  font-size: 16px;
  font-weight: 500;
  color: #000000e5;
  text-align: center;
  flex: 1;
}

.popup-header .btn {
  font-size: 14px;
  font-weight: 500;
}

.popup-header .cancel {
  color: #00000099;
}

.popup-header .confirm {
  color: #0091ff;
}
