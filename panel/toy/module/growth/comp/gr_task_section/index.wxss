@import "/asset/icon.wxss";

.task-tab {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.sdk-icon.xiala {
  font-size: 7px;
  color: #000000d9;
  transform: rotate(-90deg);
  transition: transform 0.2s ease;
}

.sdk-icon.xiala.expanded {
  transform: rotate(0deg);
}

@keyframes slide-down {
  from {
    transform: translateY(-10px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.task-cell-content {
  margin-bottom: 12px;
  animation: slide-down 0.4s ease;
}

.task-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
  padding: 16px;
}

.task-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  background-color: #d9d9d9;
}

.task-icon-img {
  width: 100%;
  height: 100%;
}

.task-name {
  font-size: 14px;
  font-weight: 500;
  color: #080f19;
}
