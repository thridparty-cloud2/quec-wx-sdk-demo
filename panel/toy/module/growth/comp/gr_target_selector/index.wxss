@import "/asset/icon.wxss";

.selector-content {
  display: flex;
  flex-direction: column;
}

.selector-tab {
  width: 84px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  padding: 4px 4px 4px 8px;
  gap: 8px;
  margin-bottom: 16px;
}

.tab-title {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #080f19;
  font-size: 14px;
  font-weight: 500;
}

.sdk-icon.xiala {
  font-size: 7px;
  color: #000000d9;
  transform: rotate(-90deg);
  transition: transform 0.2s ease;
}

.sdk-icon.xiala.expanded {
  transform: rotate(0deg);
}

.target-content {
  display: grid;
  justify-items: center;
  row-gap: 20px;
  column-gap: 48px;
  grid-template-columns: repeat(3, 1fr);
  margin: 0 0 32px 0;
  padding: 0 24px;
  animation: slide-down 0.3s ease;
}

@keyframes slide-down {
  from {
    transform: translateY(-4px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.target-item {
  width: 64px;
  height: 81px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  position: relative;
}

.check-icon {
  width: 20px;
  height: 20px;
  position: absolute;
  left: 63%;
  top: 0;
}

.target-icon {
  width: 54px;
  height: 54px;
  border: 1px solid #ffffff;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #fff;
}

.target-icon.has-selected {
  border-color: #0091ff;
}

.icon-img {
  width: 100%;
  height: 100%;
}

.target-name {
  font-size: 12px;
  font-weight: 400;
  color: #080f19;
}

.target-item.disabled .target-icon {
  opacity: 0.5;
}

.target-item.disabled .target-name {
  color: #cecfd1;
}

.seat-box {
  width: 100%;
  height: 190px;
}

.seat-box._top {
  height: 20px;
}
