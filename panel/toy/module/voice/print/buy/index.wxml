<nav_bar title="声纹识别服务" icon="icon_dingdan" bindIconEv="goOrder"></nav_bar>
<view class="set" style="height: {{sHei}}px;">
  <view class="pack">
    <view wx:for="{{sets}}" wx:key="index" data-item="{{item}}" class="item {{item.check?'active':''}}" catchtap="changeSet">
      <view class="name">
        <text class="package-name">{{item.packageName}}</text>
        <text class="rmb">¥</text><text class="price">{{item.packagePriceYuan}}</text>
      </view>
      <view class="desc">套餐描述：{{item.packageDesc}}</view>
    </view>
  </view>
  <view class="sevice">
    <view class="h4">服务说明</view>
    <view class="desc">
      <text class="p">声纹识别是通过提取语音中的声道结构、发音习惯等生物特征进行身份识别的技术。即使语言相同，每个人的声纹也像指纹一样独特，误差率低于0.1%。</text>
      <text class="p">开通该服务可以：</text>
      <view class="ul">
        <text class="li p"><text class="disc"></text>特定人的声纹才可以唤醒和智能体对话</text>
        <text class="li p"><text class="disc"></text>可以在本次和智能体连接的时候知道当前说话人的身份</text>
        <text class="li p"><text class="disc"></text>识别每一次对话中对话人的身份，只响应指定声纹人的回答或打断</text>
      </view>
    </view>
  </view>
</view>

<view class="btn m0">
  <van-button type="info" custom-class="aiBtn" disabled="{{false}}" custom-style="{{'border-radius:100px'}}" color="#0091FF" block catchtap="payNow">立即支付 <text class="unit">¥</text> <text class="price">{{cur.packagePriceYuan}}</text></van-button>
  <view class="tip">
    <view class="cbox">
      <van-checkbox value="{{ payCheck }}" name="checked" icon-size="14px" checked-color="#0091FF" bind:change="payCheckChange"></van-checkbox>
    </view>
    <view class="word"><text>购买前请仔细阅读 <text class="blue" catchtap="toProtocol">《服务协议》</text>，确认付款后即视为同意本协议</text></view>
  </view>
</view>


<!-- 同意协议 -->
<pay_agree visible="{{agreeShow}}" type="{{2}}" bind:close="agreeClose" bind:confirm="agreeConfirm"></pay_agree>

<!--  付款信息弹窗 ctype:  'AI_MUSIC'-内容服务 'AI_VOICE_PRINT'-声纹识别 'AI_VOICE_CLONE'-声音复刻  -->
<pay_info visible="{{payInfoVisible}}" package="{{cur}}" ctype="{{cur.packageType}}" bind:close="closePay" bindGiveup="closePay" bindPaySuccess="successPay" bindContinue="continuePay" />
<sos_warn device="{{curDevice}}" />