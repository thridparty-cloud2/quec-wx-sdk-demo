@import "/asset/base.wxss";
@import "../../../../../../asset/icon.wxss";

.bg {
  background: #000e21;
  height: 100vh;
  overflow: hidden;
}

.sdk-icon {
  font-size: 24px;
}

.del_room {
  color: #ff4219;
}

.van-icon-arrow-left {
  color: #fff !important;
}

.van-nav-bar {
  background-color: transparent !important;
}

.head {
  padding: 30rpx 40rpx;
}

.head .tit,
.head .tip {
  color: #fff;
}

.head .tit {
  font-size: 20px;
  font-weight: 500;
}

.head .tip {
  color: #cecfd1;
  font-size: 12px;
  line-height: 140%;
  padding: 14rpx 0 18rpx;
}

.head .expire-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.head .expire {
  display: inline-block;
  border-radius: 2px;
  background: #f1dfb2;
  color: #46340a;
  font-size: 12px;
  padding: 2rpx 10rpx;
}

.expired {
  background: #ffeeea !important;
  color: #ff4219 !important;
}

.head .renew-btn {
  display: inline-block;
  border-radius: 2px;
  background: #1890ff;
  color: #fff;
  font-size: 12px;
  padding: 4rpx 12rpx;
  cursor: pointer;
  transition: background-color 0.3s;
}

.head .renew-btn:active {
  background: #096dd9;
}

.list {
  height: 80vh;
  border-radius: 12px 12px 0 0;
  background: #f7f8fc;
  display: flex;
  align-items: center;
  justify-content: center;
}
.list-loading {
  height: 80vh;
  border-radius: 12px 12px 0 0;
  background: #f7f8fc;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loading-text {
  color: #9c9fa3;
  font-size: 14px;
}

.more-option {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  cursor: pointer;
}

.option-text {
  margin-left: 16rpx;
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: transparent;
  z-index: 999;
}

/* 关闭状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 343px;
  height: 248px;
  padding: 120px 16px 0 16px;
}

.empty-img {
  width: 240px;
  height: 140px;
  margin-bottom: 40rpx;
  /* opacity: 0.6; */
}

.empty-text {
  color: #9c9fa3;
  font-size: 14px;
  font-weight: 400;
}

/* 服务过期状态样式 */
.expire-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 343px;
  height: 248px;
  padding: 120px 16px 0 16px;
}

.expire-img {
  width: 240px;
  height: 140px;
  margin-bottom: 40rpx;
}

.expire-text {
  font-size: 14px;
  color: #9c9fa3;
  font-weight: 400;
  text-align: center;
  margin-bottom: 64rpx;
}

.expire-btn {
  width: 240rpx;
  height: 80rpx;
  background: #0091ff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: background-color 0.3s;
  border: none;
}

/* 开启状态样式 */
.content {
  padding-top: 20rpx;
}

.create-section {
  margin-bottom: 40rpx;
}

.create-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  width: 343px;
  height: 248px;
  padding: 120px 16px 0 16px;
}

.create-img {
  width: 480rpx;
  height: 280rpx;
}

.create-text {
  color: #9c9fa3;
  font-size: 14px;
  font-weight: 400;
  margin-top: 40rpx;
  margin-bottom: 48rpx;
}

.create-btn {
  width: 288rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background-color: #0091ff;
  font-size: 16px;
  font-weight: 500;
  color: #ffffff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 声纹配置列表样式 */
.voice-list {
  padding: 40rpx;
}

.voice-section {
  margin-bottom: 60rpx;
}

.voice-section-title {
  color: #000000e5;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 16rpx;
  margin-left: 8rpx;
}

.voice-item {
  min-height: 50px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 12px;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 24rpx;
}

.voice-info {
  display: flex;
  align-items: flex-start;
  flex: 1;
  flex-direction: column;
}

.voice-main {
  display: flex;
  align-items: center;
  width: 100%;
  height: 36px;
}

.voice-icon {
  margin-right: 24rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-text-container {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1;
}

.voice-name {
  color: #333;
  font-size: 16px;
  font-weight: 600;
}

.voice-status {
  color: #ff6600;
  font-size: 14px;
  font-weight: 400;
  margin-top: 4rpx;
}

.play-indicator {
  margin-top: 8rpx;
  margin-left: 60rpx;
}

.play-text {
  font-size: 24rpx;
  color: #666;
  opacity: 0.8;
}

.voice-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

.more-btn {
  padding: 8rpx;
  cursor: pointer;
}

/* 编辑弹窗样式 */
.popup-content {
  text-align: center;
  padding: 14px 25px 0 25px;
}

.edit-popup-title {
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.edit-popup-input {
  background-color: #f7f8fc;
  border-radius: 16rpx;
  margin-bottom: 56rpx;
  width: 100%;
  height: 50px;
}

.edit-input {
  font-size: 32rpx;
  color: #333;
  text-align: left;
  padding: 14px 12px;
}

.edit-popup-buttons {
  border-top: 1px solid #e7e7e7;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 56px;
  gap: 24px;
}

.edit-btn {
  flex: 1;
  text-align: center;
  cursor: pointer;
}

.middle-line {
  width: 1px;
  height: 100%;
  background-color: #e7e7e7;
  display: flex;
  align-self: stretch;
}

.edit-btn.confirm-btn {
  color: #0091ff;
}

.delete-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  margin-top: 14px;
}

.delete-popup-desc {
  font-size: 28rpx;
  font-weight: 400;
  margin-bottom: 56rpx;
  text-align: left;
}

.delete-popup-buttons {
  border-top: 1px solid #e7e7e7;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 56px;
  gap: 24px;
}

.delete-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  cursor: pointer;
}

.delete-btn.confirm-btn {
  color: #ff4219;
}

.tianjiapeiwangshebei {
  font-size: 24px;
  color: #0091ff;
}

.add-voice-section {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 20px;
  padding: 16px 12px;
  margin-bottom: 10vh;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  border-radius: 12px;
  background-color: #ffffff;
}

.empty-view {
  height: 10vh;
}

.add-voice-icon {
  margin-right: 16rpx;
  background-color: #e8f5ff;
  border-radius: 50%;
  font-weight: 600;
  width: 20px;
  height: 20px;
}

/* 应用声纹空状态样式 */
.empty-applied-voice {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx;
  border-radius: 12px;
  background-color: #ffffff;
}

.empty-applied-text {
  color: #9c9fa3;
  font-size: 12px;
  font-weight: 400;
  line-height: 24px;
}

.van-cell__title {
  color: #080f19 !important;
  font-size: 16px !important;
  font-weight: 500 !important;
}

.van-cell__label {
  color: #6b6f75 !important;
  font-size: 12px !important;
  font-weight: 400 !important;
}

/* 录音弹窗样式 */
.copy-voice-popup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 20px;
}

.copy-voice-popup-title {
  color: #080f19 !important;
  text-align: center;
  font-size: 20px;
  font-weight: 600;
}

.copy-voice-popup-precautions {
  color: #080f19;
  font-size: 16px;
  font-weight: 400;
  text-align: start;
}

.copy-voice-popup-precautions-content {
  display: flex;
  flex-direction: column;
  align-items: start;
  padding: 16px 20px;
  gap: 12px;
}

.copy-voice-popup-precautions .time-text {
  color: #ff6600;
}

.copy-voice-popup-lang-change {
  flex-direction: row;
  position: relative;
}

.copy-voice-choice-lang {
  display: flex;
  width: 120px;
  padding: 12px 0;
  flex-direction: column;
  align-items: flex-start;
  border-radius: 16px;
  background: #fff;
  box-shadow: 0 2px 9px 0 rgba(0, 0, 0, 0.1);
  position: absolute;
  top: 30px;
}

.lang-btn {
  border-color: transparent !important;
  width: 120px !important;
  height: 34px !important;
}

.lang-btn-selected {
  color: #0091ff !important;
}

.copy-voice-popup-lang-change .change-lang-icon {
  margin-left: 8px;
}

.copy-voice-popup-copy-content {
  height: 100px;
  margin-top: 50px;
  margin-bottom: 150px;
}

.copy-voice-popup-btn1 {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 20rpx;
}

.copy-voice-popup-btn1 .btn {
  flex: 1;
}

.copy-voice-button {
  text-align: center;
  font-size: 16px !important;
  font-weight: 500;
}

.grey-color {
  color: #6b6f75 !important;
}

.record-btn {
  width: 90%;
  height: 54px;
  box-sizing: border-box;
  background-color: #f5f5f5;
  text-align: center;
  border-radius: 7px;
  border: none;
  position: absolute;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  top: 80%;
}

.record-btn-red {
  background: linear-gradient(90deg, #ff4219 0%, #ff4219 100%);
  background-size: 100% 100%;
}

.record-btn-blue {
  background: linear-gradient(90deg, #0091ff 0%, #0091ff 100%);
  background-size: 100% 100%;
}

.record-btn-text {
  color: #333;
  font-size: 16px;
  font-weight: 500;
  z-index: 1;
  position: relative;
}

.record-btn-blue .record-btn-text,
.record-btn-red .record-btn-text {
  color: #fff;
  font-size: 16px;
  font-weight: 600;
}

.record-btn-top-text {
  color: var(--text-black-2, #6b6f75);
  text-align: center;
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 24px;
  position: absolute;
  top: 75%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.text-red {
  color: red;
}

.copy-voice-popup-btn2 {
  /* 空样式，用于第三步时的占位 */
}

.edit-vpf-popup {
  width: 311px;
  border-radius: 16px;
  font-size: 16px;
  font-weight: 600;
}

.delete-vpf-popup {
  width: 311px;
  border-radius: 16px;
  font-size: 16px;
  font-weight: 600;
}

.van-dialog__footer {
  height: 56px;
}

.van-button__text {
  font-size: 16px !important;
  font-weight: 600 !important;
}

.van-dialog__header {
  font-size: 16px !important;
  font-weight: 600 !important;
}

.back-dialog {
  font-size: 16px;
  font-weight: 600;
}
