<wxs module="tools" src="../../../../../../utils/common.wxs"></wxs>
<nav_bar title="声音克隆服务" icon="icon_dingdan" bindIconEv="toOrderPage"></nav_bar>
<view class="main">
  <view class="container">
    <!-- 套餐选择 -->
    <view class="package-section">
      <view class="package-item {{index === selectedPackageIndex ? 'active' : ''}}" wx:for="{{packageList}}" wx:key="index" wx:for-index="index" bindtap="selectPackage" data-index="{{index}}">
        <view class="package-info-row">
          <view class="package-left">
            <view class="package-name">{{item.packageName}}</view>
            <view class="package-price">
              <text class="currency">
                {{ tools.getMapValByKey(item.packageCurrencyCode, currencyUnitMap)}}
              </text>
              <text class="price">{{item.packagePriceYuan}}</text>
            </view>
          </view>
          <view class="package-right">
            <!-- 使用quantities对象中对应index的值 -->
            <van-stepper value="{{ quantities[index] || 1 }}" min="1" max="99" integer bind:change="onChange" data-index="{{index}}" input-class="stepper-input" plus-class="stepper-plus" minus-class="stepper-minus" custom-class="count-stepper" input-width="40px" button-size="24px" />
          </view>
        </view>
        <view class="package-desc">套餐描述：{{item.packageDesc}}</view>
      </view>
    </view>
    <!-- 服务说明 -->
    <view class="service-detail">
      <view class="section-title">服务说明</view>
      <view class="detail-content">
        <view class="detail-item">
          <text>1、声音克隆是指使用人工智能技术，将用户上传的录音样本分析、训练并生成与原声相似的合成语音</text>
          <text>2、解锁后仅可克隆本人声音</text>
          <text>3、克隆后的声音可用于智能设备语音交互</text>
        </view>
      </view>
    </view>
  </view>
  <!-- 底部支付区域 -->
  <view class="payment-footer">
    <view class="payment-btn">
      <van-button custom-class="pay-button" block round color="#0091ff" bindtap="handlePayment">
        <text>立即支付</text>
        <text class="pay-unit">{{ tools.getMapValByKey(selectedPackage.packageCurrencyCode, currencyUnitMap)}}</text>
        <text class="pay-price">{{totalPrice}}</text>
      </van-button>
    </view>
    <view class="agreement">
      <van-checkbox value="{{agreeChecked}}" bind:change="onAgreeChange" icon-size="18px" checked-color="#0091ff"></van-checkbox>
      <view class="agreement-text">
        <text>购买前请仔细阅读</text>
        <text class="link" bindtap="viewServiceAgreement">《服务协议》</text>
        <text>,确认付款后即视为同意本协议</text>
      </view>
    </view>
  </view>
</view>
<!-- 同意协议 -->
<pay_agree visible="{{agreeShow}}" type="{{3}}" bind:close="agreeClose" bind:confirm="agreeConfirm"></pay_agree>
<!-- 付款信息弹窗 ctype: 'AI_MUSIC'-内容服务 'AI_VOICE_PRINT'-声纹识别 'AI_VOICE_CLONE'-声音复刻 -->
<pay_info visible="{{payInfoVisible}}" package="{{selectedPackage}}" ctype="{{selectedPackage.packageType}}" amount="{{quantities[selectedPackageIndex]}}" bind:close="closePay" bindGiveup="closePay" bindPaySuccess="successPay" bindContinue="continuePay" />
<sos_warn device="{{curDevice}}" />