/* 录音弹窗公共组件样式 */
@import "/asset/icon.wxss";

.qiehuanwangluo {
  color: #0091ff;
}

.lang-text {
  color: #6b6f75;
}

.voice-record-popup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 20px;
}

.voice-record-popup-title {
  color: #080f19 !important;
  text-align: center;
  font-size: 20px;
  font-weight: 600;
}

.voice-record-popup-precautions {
  color: #080f19;
  font-size: 16px;
  font-weight: 400;
  text-align: start;
}

.voice-record-popup-precautions-content {
  display: flex;
  flex-direction: column;
  align-items: start;
  padding: 16px 20px;
  gap: 12px;
}

.voice-record-popup-precautions .time-text {
  color: #ff6600;
}

.voice-record-popup-lang-change {
  flex-direction: row;
  position: relative;
}

.lang-mask {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
  /* 低于语言选择弹层，高于其它内容 */
}

.voice-record-choice-lang {
  display: flex;
  width: 120px;
  padding: 12px 0;
  flex-direction: column;
  align-items: flex-start;
  border-radius: 16px;
  background: #fff;
  box-shadow: 0 2px 9px 0 rgba(0, 0, 0, 0.1);
  position: absolute;
  top: 30px;
  z-index: 2;
  /* 高于遮罩 */
}

.lang-btn {
  border-color: transparent !important;
  width: 120px !important;
  height: 34px !important;
}

.lang-btn-selected {
  color: #0091ff !important;
}

.voice-record-popup-lang-change .change-lang-icon {
  margin-left: 8px;
}

.voice-record-popup-copy-content {
  height: 100px;
  margin-top: 50px;
  margin-bottom: 150px;
}

.voice-record-popup-btn1 {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 36px;
}

.voice-record-popup-btn1 .btn {
  flex: 1;
}

.voice-record-button {
  font-size: 16px !important;
  font-weight: 600 !important;
}

.record-btn {
  width: 90%;
  height: 54px;
  box-sizing: border-box;
  background-color: #f5f5f5;
  text-align: center;
  border-radius: 7px;
  border: none;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.record-btn-red {
  background: linear-gradient(90deg, #ff4219 0%, #ff4219 100%);
  background-size: 100% 100%;
}

.record-btn-blue {
  background: linear-gradient(90deg, #0091ff 0%, #0091ff 100%);
  background-size: 100% 100%;
}

.record-btn-text {
  color: #333;
  font-size: 16px;
  font-weight: 500;
  z-index: 1;
  position: relative;
}

.record-btn-blue .record-btn-text,
.record-btn-red .record-btn-text {
  color: #fff;
  font-size: 16px;
  font-weight: 600;
}

.record-btn-top-text {
  color: var(--text-black-2, #6b6f75);
  text-align: center;
  font-size: 14px;
  font-style: normal;
  font-weight: 400;
  line-height: 24px;
  position: absolute;
  top: 70%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.text-red {
  color: red;
}

.grey-color {
  background-color: #f7f8fc !important;
  color: #6b6f75 !important;
}

.voice-record-popup-btn2 {
  /* 空的按钮区域，用于第三步 */
}