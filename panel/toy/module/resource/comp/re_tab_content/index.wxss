.package-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.package-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 48rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid #e0e0e0;
  background: #fff;
  position: relative;
}

.is-selected {
  border-color: #0091ff;
  background: rgba(0, 145, 255, 0.05);
}

.package-name,
.package-price {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.package-name-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.price-text {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.price-unit {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.price-num {
  font-size: 60rpx;
  font-weight: 600;
  color: #333;
}

.package-des {
  display: block;
  font-size: 24rpx;
  color: #6b6f75;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.service-des {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 48rpx;
}

.des-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.des-content {
  display: flex;
  flex-direction: column;
  font-size: 24rpx;
  color: #666;
}

.service-content-item {
  line-height: 40rpx;
}
