.resource-buy-card {
  margin-top: 24rpx;
  padding: 0 32rpx;
  background-color: #ffffff;
  flex: 1;
  overflow: hidden;
  min-height: 100%;
}

.unpaid {
  padding: 0 32rpx;
  background-color: #fff;
  border-radius: 0;
  min-height: 100%;
}

.footer-sec {
  display: flex;
  flex-direction: column;
  padding: 40rpx 40rpx 68rpx;
  gap: 24rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
}

.buy-btn {
  border-radius: 200rpx !important;
}

.buy-tip {
  display: flex;
  gap: 4rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #9c9fa3;
  padding-right: 40rpx;
}

.tip-text span {
  color: #0091ff;
}

.tab-class {
  font-size: 32rpx;
  color: #9c9fa3;
}

.tab-active-class {
  color: #080f19;
}

.single-tab-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.single-tab-bar {
  width: 6rpx;
  height: 30rpx;
  background-color: #0091ff;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.single-tab-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #080f19;
}
