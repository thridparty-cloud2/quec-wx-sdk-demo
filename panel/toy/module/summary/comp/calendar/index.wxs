/**
 * 赋值日期类名
 * @param {Object} day 日期对象
 * @returns {String}
 */
function getDateCellClass(day) {
  var classes = ["date-cell"];

  // 空白占位符
  if (day.isEmpty) {
    classes.push("empty-cell");
    return classes.join(" ");
  }

  if (!day.isCurrentMonth) {
    classes.push("other-month");
  }

  if (day.isToday) {
    classes.push("today");
  }

  if (day.isFutureDate) {
    classes.push("future-date");
  }

  if (day.isSelected) {
    classes.push("selected");
  }

  if (day.hasEvent) {
    classes.push("has-event");
  }

  return classes.join(" ");
}

module.exports = {
  getDateCellClass: getDateCellClass,
};
