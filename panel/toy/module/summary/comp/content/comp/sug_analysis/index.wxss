.sug-analysis-content {
  width: 100%;
  margin-top: 32px;
}

.tab-content {
  display: flex;
  align-items: center;
  gap: 20px;
}

.tab-item {
  position: relative;
  padding-bottom: 20px;
}

.tab-item-text {
  z-index: 1;
  font-size: 16px;
  font-weight: 400;
  color: #9c9fa3;
}

.tab-item-text.isSelect {
  font-weight: 500;
  color: #080f19;
}

.tab-line {
  width: 27px;
  height: 10px;
  position: absolute;
  top: 14px;
  left: 50%;
  transform: translateX(-50%);
}

.content-container {
  position: relative;
  width: 100%;
}

.content-detail.fade-in {
  opacity: 1;
  transform: translateY(0);
}

.content-detail {
  padding-bottom: 48rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease-in-out;
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.content-title {
  display: flex;
  align-items: center;
  padding: 8px 8px 8px 4px;
  border-radius: 4px;
  margin-bottom: 12px;
  gap: 8px;
}

.title-text {
  font-size: 14px;
  font-weight: 500;
  color: #080f19;
}

.content-card {
  width: 100%;
  display: flex;
  flex-direction: column;
  padding: 4px 12px 16px 12px;
  font-size: 14px;
  line-height: 1.6;
  color: #080f19;
  word-wrap: break-word;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.content-text-item {
  line-height: 24px;
}

.list-content {
  display: flex;
  flex-direction: column;
  word-wrap: break-word;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.last-numbered-item {
  margin-bottom: 24px;
}
