.main-content {
  width: 100%;
}

.highlights-title {
  font-size: 16px;
  font-weight: 500;
  color: #080f19;
  margin-bottom: 12px;
}

.highlights-card {
  height: 360rpx;
  background-color: #f7f8fc;
  border-radius: 40rpx;
  position: relative;
}

.circle {
  position: absolute;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
}

.circle .text {
  white-space: pre-line;
}

.text-vertical {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.text-line {
  display: block;
  line-height: 1.2;
}

