.statistics-content {
  padding: 32px 0;
  display: flex;
  align-items: center;
  justify-content: space-evenly;
}

.druation,
.round-num {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.druation-value text,
.round-num-value {
  font-size: 28px;
  font-weight: 500;
  color: #080f19;
}

.druation-value span {
  font-size: 12px;
  font-weight: 400;
  color: #080f19;
}

.stat-title {
  font-size: 12px;
  font-weight: 400;
  color: #6b6f75;
  margin-top: 8px;
}

.driver-y {
  width: 1px;
  height: 30px;
  background: #d9d9d9;
}
