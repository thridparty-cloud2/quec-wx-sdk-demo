.enter {
  height: 94px;
  margin: 0 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.49) 0%, #EBF5FF 100%);
  padding: 12px;
  border-radius: 12px;
  box-sizing: border-box;
  position: relative;
}

.mine {
  background: #ffffff;
  padding: 12px;
  box-sizing: border-box;
}

.h2 {
  font-size: 16px;
  color: #080F19;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.item {
  position: relative;
  border: .5px solid #E6F4FF;
  height: 70px;
  border-radius: 12px;
  z-index: 10;
}

.item .bg {
  height: 70px;
  width: 100%;
}

.enter .off {
  position: absolute;
  top: 0;
  right: 0;
  z-index: 12;
}

.enter .off .cImg {
  width: 32px;
  height: 32px;
}

.icon {
  position: absolute;
  z-index: 11;
}

.icon.tel {
  top: 10px;
  right: 10px;
}

.icon.sms {
  top: 20px;
  right: 15px;
}

.telImg {
  width: 55px;
  height: 55px;
}

.smsImg {
  width: 52px;
  height: 44px;
}

.copytxt {
  position: absolute;
  top: 10px;
  left: 10px;
}

.copytxt .txt {
  font-size: 14px;
  color: #080F19;
  font-weight: bold;
  line-height: 28px;
}

.copytxt .more {
  font-size: 12px;
  color: #0091FF;
}